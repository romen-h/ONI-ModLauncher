<?xml version="1.0" encoding="utf-8" ?>
<Project>

  <Target Name="GenerateLauncherMetadata" AfterTargets="AfterBuild" Outputs="$(TargetDir)LauncherMetadata.json"
          Condition="'$(GenerateModLauncherMetadata)' == 'true'">
    <!--Properties and Items used here should be overridden in the mod project file.-->
    <GenerateLauncherMetadata TargetDir="$(TargetDir)"
                              ModStaticId="$(ModStaticId)"
                              Version="$(Version)"
                              SteamWorkshopId="$(SteamWorkshopId)"
                              Title="$(ModName)"
                              Authors="$(Authors)"
                              AuthorUrls="@(AuthorUrls)"
                              Dependencies="@(Dependencies)"
                              Category="$(ModLauncherCategory)"
                              Keywords="$(ModLauncherKeywords)"
                              UpdateIndexUrl="$(ModLauncherUpdateIndexUrl)"
                              UpdateNestedPath="$(ModLauncherUpdateNestedPath)"
                              UpdatePreservedFiles="@(ModLauncherUpdatePreservedFiles)"/>
  </Target>

  <Target Name="AfterClean">
    <Delete Files="$(TargetDir)LauncherMetadata.json" />
  </Target>

</Project>